<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Software Store - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --indian-orange: #FF6B35;
            --web-green: #00C853;
        }
        .btn-orange {
            background: linear-gradient(90deg, #FF6B35 0%, #FF8C42 100%);
            transition: all 0.3s ease;
        }
        .btn-orange:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255, 107, 53, 0.3);
        }
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        }
        .indian-text { color: #FF6B35; }
        .web-text { color: #00C853; }
    </style>
</head>
<body class="bg-gray-50">

    <!-- Navbar -->
    <nav class="bg-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="text-2xl font-bold">
                    <span class="indian-text">INDIAN</span>
                    <span class="web-text">WEB</span>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="text-gray-700 hover:text-orange-500">Home</a>
                    <a href="/store" class="text-orange-500 font-bold">Store</a>
                    <a href="/custom-order" class="text-gray-700 hover:text-orange-500">Custom Order</a>
                    <a href="/support" class="text-gray-700 hover:text-orange-500">Support</a>
                    <a href="/contact" class="text-gray-700 hover:text-orange-500">Contact</a>
                </div>
                <div>
                    <a href="/cart" class="relative text-2xl">🛒<span id="cartCount" class="absolute -top-2 -right-4 bg-red-500 text-white rounded-full px-1 text-xs">0</span></a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Store Header -->
    <section class="hero-gradient text-white py-16" style="background: linear-gradient(135deg, #FF6B35 0%, #00C853 100%);">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-5xl font-bold mb-4">📦 Software Store</h1>
            <p class="text-xl">Browse our collection of premium software applications</p>
        </div>
    </section>

    <!-- Software Grid -->
    <section class="py-16">
        <div class="container mx-auto px-6">
            <% if (typeof software !== 'undefined' && software && software.length > 0) { %>
            <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-8">
                <% software.forEach(function(item, index) { %>
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden card-hover" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
                    <img src="<%= item.imageUrl || '/images/default-software.jpg' %>" class="w-full h-48 object-cover" onerror="this.src='/images/default-software.jpg'">
                    <div class="p-5">
                        <h3 class="text-xl font-bold mb-2"><%= item.name %></h3>
                        <p class="text-gray-600 text-sm mb-3"><%= item.description ? item.description.substring(0, 80) : 'No description' %>...</p>
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-2xl font-bold text-orange-600">₹<%= item.price %></span>
                            <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">v<%= item.version || '1.0' %></span>
                        </div>
                        <div class="flex space-x-2">
                            <% if(item.demoUrl) { %>
                            <a href="<%= item.demoUrl %>" target="_blank" class="flex-1 text-center border border-blue-500 text-blue-500 py-2 rounded-lg hover:bg-blue-500 hover:text-white transition">Demo</a>
                            <% } %>
                            <button onclick="addToCart('<%= item._id %>', '<%= item.name.replace(/'/g, "\\'") %>', <%= item.price %>)" class="flex-1 btn-orange text-white py-2 rounded-lg">Buy</button>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
            <% } else { %>
            <div class="text-center py-20">
                <div class="text-6xl mb-4">📦</div>
                <h2 class="text-2xl font-bold text-gray-600">No Software Available</h2>
                <p class="text-gray-500 mt-2">Please add some software from admin panel</p>
                <a href="/admin/login" class="btn-orange text-white px-6 py-3 rounded-lg inline-block mt-6">Go to Admin Panel</a>
            </div>
            <% } %>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gray-900 text-white py-10 mt-12">
        <div class="container mx-auto px-6 text-center">
            <p>&copy; 2025 <span class="text-orange-500">INDIAN</span><span class="text-green-500">WEB</span>. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
        
        function addToCart(id, name, price) {
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ softwareId: id, name: name, price: price })
            }).then(function(res) { return res.json(); }).then(function(data) {
                if(data.success) {
                    alert('✅ ' + name + ' added to cart!');
                    updateCartCount();
                }
            }).catch(function() {
                alert('✅ ' + name + ' added to cart!');
                updateCartCount();
            });
        }
        
        function updateCartCount() {
            fetch('/api/cart-count').then(function(res) { return res.json(); }).then(function(data) {
                document.getElementById('cartCount').innerText = data.count || 0;
            }).catch(function() {});
        }
        updateCartCount();
    </script>
</body>
</html>