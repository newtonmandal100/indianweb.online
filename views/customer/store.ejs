<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Software Store - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .btn-gradient { background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%); }
        .card-hover { transition: all 0.3s ease; }
        .card-hover:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.15); }
    </style>
</head>
<body class="bg-gray-50">

    <!-- Navbar -->
    <nav class="bg-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-3">
                    <% if(locals.siteSettings && locals.siteSettings.logo) { %>
                    <img src="<%= locals.siteSettings.logo %>" style="width: 120px;">
                    <% } else { %>
                    <span class="text-2xl font-bold"><span class="text-purple-600">INDIAN</span><span class="text-pink-600">WEB</span></span>
                    <% } %>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="text-gray-700 hover:text-purple-600">Home</a>
                    <a href="/store" class="text-purple-600 font-bold">Store</a>
                    <a href="/custom-order" class="text-gray-700 hover:text-purple-600">Custom Order</a>
                    <a href="/support" class="text-gray-700 hover:text-purple-600">Support</a>
                </div>
                <div>
                    <a href="/cart" class="relative text-2xl">🛒<span id="cartCount" class="absolute -top-2 -right-4 bg-red-500 text-white rounded-full px-1 text-xs">0</span></a>
                </div>
            </div>
        </div>
    </nav>

    <!-- Store Header -->
    <section class="gradient-bg text-white py-16">
        <div class="container mx-auto px-6 text-center">
            <h1 class="text-5xl font-bold mb-4">📦 Software Store</h1>
            <p class="text-xl">Browse our collection of premium software applications</p>
        </div>
    </section>

    <!-- Software Grid -->
    <section class="py-16">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-8">
                <% software.forEach((item, index) => { %>
                <div class="bg-white rounded-2xl shadow-lg overflow-hidden card-hover" data-aos="fade-up" data-aos-delay="<%= index * 50 %>">
                    <img src="<%= item.imageUrl %>" class="w-full h-48 object-cover">
                    <div class="p-5">
                        <h3 class="text-xl font-bold mb-2"><%= item.name %></h3>
                        <p class="text-gray-600 text-sm mb-3"><%= item.description.substring(0, 80) %>...</p>
                        <div class="flex items-center justify-between mb-3">
                            <span class="text-2xl font-bold text-purple-600">₹<%= item.price %></span>
                            <span class="text-xs bg-green-100 text-green-700 px-2 py-1 rounded">v<%= item.version %></span>
                        </div>
                        <div class="flex space-x-2">
                            <% if(item.demoUrl) { %>
                            <a href="<%= item.demoUrl %>" target="_blank" class="flex-1 text-center border border-blue-500 text-blue-500 py-2 rounded-lg hover:bg-blue-500 hover:text-white transition">Demo</a>
                            <% } %>
                            <button onclick="addToCart('<%= item._id %>', '<%= item.name %>', <%= item.price %>)" class="flex-1 btn-gradient text-white py-2 rounded-lg">Buy</button>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </section>

    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
        function addToCart(id, name, price) {
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ softwareId: id, name, price })
            }).then(res => res.json()).then(data => {
                if(data.success) { alert('✅ Added to cart!'); location.reload(); }
            });
        }
        function updateCartCount() {
            fetch('/api/cart-count').then(res => res.json()).then(data => {
                document.getElementById('cartCount').innerText = data.count;
            });
        }
        updateCartCount();
    </script>
</body>
</html>,