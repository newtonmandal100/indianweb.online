<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Checkout - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
</head>
<body class="bg-gray-50">

    <div class="container mx-auto px-6 py-12">
        <h1 class="text-3xl font-bold text-center mb-8">💳 Checkout</h1>
        
        <div class="max-w-2xl mx-auto bg-white rounded-xl shadow-lg p-8">
            <form id="checkoutForm">
                <div class="mb-4">
                    <label class="block font-semibold mb-2">Full Name</label>
                    <input type="text" id="name" required class="w-full p-3 border rounded-lg">
                </div>
                <div class="mb-4">
                    <label class="block font-semibold mb-2">Email</label>
                    <input type="email" id="email" required class="w-full p-3 border rounded-lg">
                </div>
                <div class="mb-4">
                    <label class="block font-semibold mb-2">Phone</label>
                    <input type="tel" id="phone" required class="w-full p-3 border rounded-lg">
                </div>
                
                <div class="border-t pt-4 mt-4">
                    <h3 class="text-xl font-bold mb-2">Order Summary</h3>
                    <% cart.forEach(item => { %>
                    <div class="flex justify-between py-2">
                        <span><%= item.name %></span>
                        <span>₹<%= item.price %></span>
                    </div>
                    <% }); %>
                    <div class="flex justify-between font-bold text-lg border-t pt-2 mt-2">
                        <span>Total</span>
                        <span class="text-purple-600">₹<%= total + Math.round(total * 0.18) %></span>
                    </div>
                </div>
                
                <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white py-3 rounded-lg font-bold mt-6">Pay Now</button>
            </form>
        </div>
    </div>

    <script>
        const totalAmount = <%= total + Math.round(total * 0.18) %>;
        
        document.getElementById('checkoutForm').onsubmit = async (e) => {
            e.preventDefault();
            
            const response = await fetch('/create-order', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' }
            });
            const order = await response.json();
            
            const options = {
                key: order.key,
                amount: order.amount,
                currency: 'INR',
                name: 'INDIAN WEB',
                description: 'Software Purchase',
                order_id: order.orderId,
                handler: function(response) {
                    const formData = new FormData();
                    formData.append('razorpay_payment_id', response.razorpay_payment_id);
                    formData.append('razorpay_order_id', response.razorpay_order_id);
                    formData.append('razorpay_signature', response.razorpay_signature);
                    formData.append('customerName', document.getElementById('name').value);
                    formData.append('customerEmail', document.getElementById('email').value);
                    formData.append('customerPhone', document.getElementById('phone').value);
                    
                    fetch('/payment-success', {
                        method: 'POST',
                        body: formData
                    }).then(() => {
                        window.location.href = '/invoice';
                    });
                },
                theme: { color: '#7c3aed' }
            };
            const rzp = new Razorpay(options);
            rzp.open();
        };
    </script>
</body>
</html>