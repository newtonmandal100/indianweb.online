<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Custom Software Order - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gradient-to-br from-purple-50 to-pink-50">

    <div class="container mx-auto px-6 py-12">
        <div class="max-w-3xl mx-auto">
            <div class="text-center mb-8">
                <h1 class="text-4xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">🎨 Custom Software Order</h1>
                <p class="text-gray-600 mt-2">Tell us what you need, and we'll build it for you!</p>
            </div>
            
            <div class="bg-white rounded-2xl shadow-xl p-8">
                <form action="/custom-order" method="POST">
                    <div class="grid md:grid-cols-2 gap-6">
                        <div>
                            <label class="block font-semibold mb-2">Your Name *</label>
                            <input type="text" name="name" required class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-purple-400">
                        </div>
                        <div>
                            <label class="block font-semibold mb-2">Email *</label>
                            <input type="email" name="email" required class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-purple-400">
                        </div>
                        <div>
                            <label class="block font-semibold mb-2">Phone</label>
                            <input type="tel" name="phone" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-purple-400">
                        </div>
                        <div>
                            <label class="block font-semibold mb-2">Software Name *</label>
                            <input type="text" name="softwareName" required class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-purple-400">
                        </div>
                    </div>
                    
                    <div class="mt-4">
                        <label class="block font-semibold mb-2">Software Description *</label>
                        <textarea name="description" rows="4" required class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-purple-400" placeholder="Describe what the software should do..."></textarea>
                    </div>
                    
                    <div class="mt-4">
                        <label class="block font-semibold mb-2">Features Required</label>
                        <textarea name="features" rows="3" class="w-full p-3 border rounded-lg focus:ring-2 focus:ring-purple-400" placeholder="List all features you need..."></textarea>
                    </div>
                    
                    <div class="grid md:grid-cols-2 gap-6 mt-4">
                        <div>
                            <label class="block font-semibold mb-2">Budget Range</label>
                            <select name="budget" class="w-full p-3 border rounded-lg">
                                <option value="< ₹10,000">< ₹10,000</option>
                                <option value="₹10,000 - ₹25,000">₹10,000 - ₹25,000</option>
                                <option value="₹25,000 - ₹50,000">₹25,000 - ₹50,000</option>
                                <option value="₹50,000 - ₹1,00,000">₹50,000 - ₹1,00,000</option>
                                <option value="> ₹1,00,000">> ₹1,00,000</option>
                            </select>
                        </div>
                        <div>
                            <label class="block font-semibold mb-2">Expected Timeline</label>
                            <select name="timeline" class="w-full p-3 border rounded-lg">
                                <option value="1-2 weeks">1-2 weeks</option>
                                <option value="1 month">1 month</option>
                                <option value="2-3 months">2-3 months</option>
                                <option value="3+ months">3+ months</option>
                            </select>
                        </div>
                    </div>
                    
                    <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white py-3 rounded-lg font-bold mt-8 hover:shadow-xl transition">
                        Submit Request →
                    </button>
                </form>
            </div>
            
            <div class="mt-8 text-center text-gray-500 text-sm">
                <p>We'll get back to you within 24 hours with a quote and timeline.</p>
            </div>
        </div>
    </div>
</body>
</html>