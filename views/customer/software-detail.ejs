<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= software.name %> - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .btn-gradient { background: linear-gradient(90deg, #f093fb 0%, #f5576c 100%); }
    </style>
</head>
<body class="bg-gray-50">

    <nav class="bg-white shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4 flex justify-between items-center">
            <div class="text-2xl font-bold"><span class="text-purple-600">INDIAN</span><span class="text-pink-600">WEB</span></div>
            <div class="space-x-6">
                <a href="/" class="text-gray-700">Home</a>
                <a href="/store" class="text-purple-600 font-bold">Store</a>
                <a href="/cart" class="text-2xl">🛒</a>
            </div>
        </div>
    </nav>

    <div class="container mx-auto px-6 py-12">
        <div class="grid md:grid-cols-2 gap-12">
            <div>
                <img src="<%= software.imageUrl %>" class="w-full rounded-2xl shadow-lg">
            </div>
            <div>
                <h1 class="text-4xl font-bold mb-4"><%= software.name %></h1>
                <p class="text-gray-600 text-lg mb-6"><%= software.description %></p>
                <div class="mb-6">
                    <span class="text-4xl font-bold text-purple-600">₹<%= software.price %></span>
                    <span class="text-gray-500 line-through ml-3">₹<%= Math.round(software.price * 1.5) %></span>
                </div>
                <div class="space-y-3 mb-8">
                    <p><i class="fas fa-tag text-purple-600"></i> Category: <%= software.category %></p>
                    <p><i class="fas fa-code-branch text-purple-600"></i> Version: <%= software.version %></p>
                    <p><i class="fas fa-download text-purple-600"></i> Downloads: <%= software.downloads %></p>
                </div>
                <div class="flex space-x-4">
                    <% if(software.demoUrl) { %>
                    <a href="<%= software.demoUrl %>" target="_blank" class="border-2 border-purple-600 text-purple-600 px-8 py-3 rounded-full font-semibold hover:bg-purple-600 hover:text-white transition">Live Demo</a>
                    <% } %>
                    <button onclick="addToCart()" class="btn-gradient text-white px-8 py-3 rounded-full font-semibold shadow-lg">Add to Cart 🛒</button>
                </div>
            </div>
        </div>

        <div class="mt-16">
            <h2 class="text-2xl font-bold mb-4">📋 Description</h2>
            <p class="text-gray-700"><%= software.longDescription || software.description %></p>
        </div>

        <% if(software.features && software.features.length) { %>
        <div class="mt-8">
            <h2 class="text-2xl font-bold mb-4">✨ Key Features</h2>
            <ul class="grid md:grid-cols-2 gap-3">
                <% software.features.forEach(feature => { %>
                <li class="flex items-center"><i class="fas fa-check-circle text-green-500 mr-2"></i> <%= feature %></li>
                <% }); %>
            </ul>
        </div>
        <% } %>
    </div>

    <script>
        function addToCart() {
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ softwareId: '<%= software._id %>', name: '<%= software.name %>', price: <%= software.price %> })
            }).then(res => res.json()).then(data => {
                if(data.success) alert('✅ Added to cart!');
            });
        }
    </script>
</body>
</html>