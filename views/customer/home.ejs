<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INDIAN WEB - Premium Software Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;600;700;800;900&family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Poppins', sans-serif;
        }
        
        /* Premium RGB Animated Background */
        body {
            background: linear-gradient(135deg, #0a0a2a 0%, #1a1a3a 50%, #0d0d2b 100%);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }
        
        /* RGB Neon Glow Effect */
        @keyframes rgbGlow {
            0% { text-shadow: 0 0 10px #ff0000, 0 0 20px #ff0000, 0 0 30px #ff0000; }
            33% { text-shadow: 0 0 10px #00ff00, 0 0 20px #00ff00, 0 0 30px #00ff00; }
            66% { text-shadow: 0 0 10px #0000ff, 0 0 20px #0000ff, 0 0 30px #0000ff; }
            100% { text-shadow: 0 0 10px #ff0000, 0 0 20px #ff0000, 0 0 30px #ff0000; }
        }
        
        /* Floating RGB Particles */
        .rgb-particle {
            position: fixed;
            width: 4px;
            height: 4px;
            background: radial-gradient(circle, #ff0000, #00ff00, #0000ff);
            border-radius: 50%;
            pointer-events: none;
            z-index: 0;
            animation: floatParticle 10s linear infinite;
        }
        
        @keyframes floatParticle {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(-20vh) rotate(720deg);
                opacity: 0;
            }
        }
        
        /* RGB Gradient Border */
        .rgb-border {
            position: relative;
            background: linear-gradient(90deg, #ff0000, #00ff00, #0000ff, #ff0000);
            background-size: 300% 100%;
            animation: rgbBorderMove 3s linear infinite;
            border-radius: 20px;
            padding: 2px;
        }
        
        @keyframes rgbBorderMove {
            0% { background-position: 0% 50%; }
            100% { background-position: 300% 50%; }
        }
        
        .rgb-border-inner {
            background: rgba(10, 10, 42, 0.95);
            border-radius: 18px;
            backdrop-filter: blur(10px);
        }
        
        /* Premium RGB Text */
        .rgb-text {
            font-family: 'Orbitron', monospace;
            font-weight: 900;
            background: linear-gradient(90deg, #ff0000, #ff8800, #ffff00, #00ff00, #0088ff, #8800ff, #ff0088, #ff0000);
            background-size: 400% 100%;
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            animation: rgbTextShift 6s linear infinite;
        }
        
        @keyframes rgbTextShift {
            0% { background-position: 0% 50%; }
            100% { background-position: 400% 50%; }
        }
        
        /* 3D Card Flip Effect */
        .card-3d {
            transition: all 0.5s ease;
            transform-style: preserve-3d;
        }
        
        .card-3d:hover {
            transform: translateY(-15px) rotateX(5deg);
            box-shadow: 0 25px 40px rgba(255,0,0,0.3), 0 0 20px rgba(0,255,0,0.2), 0 0 30px rgba(0,0,255,0.1);
        }
        
        /* Neon Button */
        .neon-btn {
            position: relative;
            background: transparent;
            border: 2px solid #00ff00;
            color: #00ff00;
            transition: all 0.3s ease;
            overflow: hidden;
        }
        
        .neon-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, #00ff00, transparent);
            transition: left 0.5s ease;
        }
        
        .neon-btn:hover::before {
            left: 100%;
        }
        
        .neon-btn:hover {
            background: #00ff00;
            color: #000;
            box-shadow: 0 0 20px #00ff00, 0 0 40px #00ff00;
        }
        
        /* Cyber Grid Background */
        .cyber-grid {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: 
                linear-gradient(rgba(0, 255, 0, 0.05) 1px, transparent 1px),
                linear-gradient(90deg, rgba(255, 0, 0, 0.05) 1px, transparent 1px);
            background-size: 40px 40px;
            pointer-events: none;
            z-index: 0;
        }
        
        /* Glowing Cards */
        .glow-card {
            background: rgba(20, 20, 50, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 255, 0, 0.2);
            transition: all 0.3s ease;
        }
        
        .glow-card:hover {
            border-color: #00ff00;
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.3), 0 0 20px rgba(255, 0, 0, 0.2);
        }
        
        /* RGB Rotating Circle */
        .rgb-circle {
            position: absolute;
            width: 300px;
            height: 300px;
            border-radius: 50%;
            background: conic-gradient(from 0deg, #ff0000, #00ff00, #0000ff, #ff0000);
            animation: rotateCircle 10s linear infinite;
            filter: blur(50px);
            opacity: 0.15;
            z-index: 0;
        }
        
        @keyframes rotateCircle {
            100% { transform: rotate(360deg); }
        }
        
        /* Logo Round Shape Premium */
        .logo-premium {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid;
            border-image: linear-gradient(90deg, #ff0000, #00ff00, #0000ff) 1;
            animation: borderGlow 2s linear infinite;
            box-shadow: 0 0 30px rgba(0,255,0,0.3);
        }
        
        @keyframes borderGlow {
            0% { border-color: #ff0000; box-shadow: 0 0 20px #ff0000; }
            50% { border-color: #00ff00; box-shadow: 0 0 20px #00ff00; }
            100% { border-color: #0000ff; box-shadow: 0 0 20px #0000ff; }
        }
        
        .content-wrapper {
            position: relative;
            z-index: 10;
        }
        
        /* Section Backgrounds */
        .section-bg {
            background: rgba(10, 10, 42, 0.8);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 255, 0, 0.1);
        }
        
        /* Stats Number Glow */
        .stat-number {
            font-family: 'Orbitron', monospace;
            animation: rgbGlow 2s ease-in-out infinite;
        }
    </style>
</head>
<body>

<!-- RGB Animated Background Elements -->
<div class="cyber-grid"></div>
<div class="rgb-circle" style="top: 10%; left: -100px;"></div>
<div class="rgb-circle" style="bottom: 10%; right: -100px; width: 400px; height: 400px;"></div>
<div class="rgb-circle" style="top: 50%; left: 50%; transform: translate(-50%, -50%); width: 500px; height: 500px; opacity: 0.08;"></div>

<!-- Floating RGB Particles -->
<script>
    for(let i = 0; i < 100; i++) {
        let particle = document.createElement('div');
        particle.className = 'rgb-particle';
        particle.style.left = Math.random() * 100 + '%';
        particle.style.animationDelay = Math.random() * 10 + 's';
        particle.style.animationDuration = 5 + Math.random() * 10 + 's';
        particle.style.width = (Math.random() * 6 + 2) + 'px';
        particle.style.height = particle.style.width;
        document.body.appendChild(particle);
    }
</script>

<!-- Main Content -->
<div class="content-wrapper">

    <!-- Navbar Premium -->
    <nav class="bg-black/50 backdrop-blur-xl border-b border-green-500/30 sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <% if(locals.siteSettings && locals.siteSettings.logo && locals.siteSettings.logo !== '/uploads/logo/default-logo.png') { %>
                        <img src="<%= locals.siteSettings.logo %>" alt="Logo" class="logo-premium">
                    <% } else { %>
                        <div class="logo-premium bg-gradient-to-r from-red-600 to-green-600 flex items-center justify-center text-white text-2xl font-bold">
                            IW
                        </div>
                    <% } %>
                    <% if(user && user.userRole === 'admin') { %>
                        <form action="/admin/upload-logo" method="POST" enctype="multipart/form-data">
                            <input type="file" name="logo" accept="image/*" class="text-xs bg-gray-800 text-white rounded p-1" onchange="this.form.submit()">
                        </form>
                    <% } %>
                    
                    <div class="text-5xl font-extrabold tracking-wider">
                        <span class="rgb-text">INDIAN</span>
                        <span class="rgb-text" style="animation-delay: 0.5s;">WEB</span>
                    </div>
                </div>
                
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="text-cyan-400 hover:text-green-400 transition font-medium">Home</a>
                    <a href="/store" class="text-cyan-400 hover:text-green-400 transition font-medium">Store</a>
                    <a href="/custom-order" class="text-cyan-400 hover:text-green-400 transition font-medium">Custom Order</a>
                    <a href="/support" class="text-cyan-400 hover:text-green-400 transition font-medium">Support</a>
                    <a href="/contact" class="text-cyan-400 hover:text-green-400 transition font-medium">Contact</a>
                </div>
                
                <div class="flex items-center space-x-4">
                    <a href="/cart" class="relative text-2xl text-white">
                        🛒
                        <span id="cartCount" class="absolute -top-2 -right-4 bg-red-500 text-white rounded-full px-1.5 py-0.5 text-xs">0</span>
                    </a>
                    <% if(user && user.userId) { %>
                        <span class="text-cyan-400 hidden sm:inline">👋 <%= user.userName %></span>
                        <a href="/logout" class="text-red-400 hover:text-red-300">Logout</a>
                    <% } else { %>
                        <a href="/login" class="neon-btn px-5 py-2 rounded-full font-semibold">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section Premium -->
    <section class="hero-bg py-28 rounded-3xl mx-6 mt-6 relative overflow-hidden"
         style="background-image: url('<%= (locals.siteSettings && locals.siteSettings.heroBackground) ? locals.siteSettings.heroBackground : 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=1600' %>'); background-size: cover; background-position: center;">
        <div class="absolute inset-0 bg-gradient-to-r from-black/70 to-purple-900/50"></div>
        <div class="container mx-auto px-6 text-center relative z-10">
            <% if(user && user.userRole === 'admin') { %>
                <div class="absolute top-4 right-4">
                    <form action="/admin/upload-hero-bg" method="POST" enctype="multipart/form-data">
                        <input type="file" name="heroBackground" accept="image/*" class="text-xs bg-black/50 text-white rounded p-1" onchange="this.form.submit()">
                    </form>
                </div>
            <% } %>
            
            <h1 class="text-7xl md:text-9xl font-bold mb-6" data-aos="fade-up">
                <span class="rgb-text">INDIAN</span>
                <span class="rgb-text" style="animation-delay: 0.3s;">WEB</span>
            </h1>
            <p class="rgb-text text-3xl md:text-4xl mb-8 max-w-3xl mx-auto" data-aos="fade-up" data-aos-delay="100" style="font-size: 2rem;">
                Premium Software Solutions
            </p>
            <p class="text-cyan-300 text-lg mb-10 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="200">
                <%= (portfolio && portfolio.heroSubtitle) ? portfolio.heroSubtitle : 'Download high-quality software for your business' %>
            </p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center" data-aos="fade-up" data-aos-delay="300">
                <a href="/store" class="neon-btn px-10 py-4 rounded-full font-bold text-xl inline-block">
                    🚀 Explore Store
                </a>
                <a href="/custom-order" class="border-2 border-cyan-400 text-cyan-400 px-10 py-4 rounded-full font-bold text-xl hover:bg-cyan-400 hover:text-black transition inline-block">
                    📝 Request Custom Software
                </a>
            </div>
        </div>
    </section>

    <!-- Stats Section Premium -->
    <section class="py-16 rounded-3xl mx-6 my-6 section-bg shadow-2xl">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-3 gap-8 text-center">
                <div class="p-6 glow-card rounded-2xl" data-aos="zoom-in">
                    <div class="text-6xl text-red-400 mb-2">📦</div>
                    <div class="stat-number text-4xl font-bold text-green-400"><%= stats.totalSoftware %></div>
                    <div class="text-cyan-400 mt-2">Software Products</div>
                </div>
                <div class="p-6 glow-card rounded-2xl" data-aos="zoom-in" data-aos-delay="100">
                    <div class="text-6xl text-green-400 mb-2">👥</div>
                    <div class="stat-number text-4xl font-bold text-green-400"><%= stats.totalCustomers %></div>
                    <div class="text-cyan-400 mt-2">Happy Customers</div>
                </div>
                <div class="p-6 glow-card rounded-2xl" data-aos="zoom-in" data-aos-delay="200">
                    <div class="text-6xl text-blue-400 mb-2">📝</div>
                    <div class="stat-number text-4xl font-bold text-green-400"><%= stats.totalOrders %></div>
                    <div class="text-cyan-400 mt-2">Orders Completed</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Software Section Premium -->
    <section class="py-20 rounded-3xl mx-6 my-6 section-bg shadow-2xl">
        <div class="container mx-auto px-6">
            <h2 class="text-5xl font-bold text-center mb-12">
                <span class="rgb-text">⭐ Featured Software</span>
            </h2>
            <div class="grid md:grid-cols-3 gap-8">
                <% if(featuredSoftware && featuredSoftware.length > 0) { %>
                    <% featuredSoftware.forEach((software, index) => { %>
                        <div class="glow-card rounded-2xl overflow-hidden card-3d"
                             data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
                            <img src="<%= software.imageUrl %>" alt="<%= software.name %>" class="w-full h-56 object-cover">
                            <div class="p-6">
                                <h3 class="text-2xl font-bold text-cyan-400 mb-2"><%= software.name %></h3>
                                <p class="text-gray-400 mb-4"><%= software.description ? software.description.substring(0, 100) : 'No description' %></p>
                                <div class="flex justify-between items-center">
                                    <div>
                                        <span class="text-3xl font-bold text-green-400">₹<%= software.price %></span>
                                    </div>
                                    <div class="space-x-2">
                                        <% if(software.demoUrl) { %>
                                            <a href="<%= software.demoUrl %>" target="_blank" class="text-cyan-400 hover:text-green-400">
                                                <i class="fas fa-eye"></i> Demo
                                            </a>
                                        <% } %>
                                        <button onclick="addToCart('<%= software._id %>', '<%= software.name %>', <%= software.price %>)" 
                                                class="neon-btn px-4 py-2 rounded-lg transition">
                                            Buy Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-3 text-center py-12 glow-card rounded-2xl">
                        <p class="text-cyan-400">No software available yet. <a href="/admin/software" class="text-green-400">Add some software</a></p>
                    </div>
                <% } %>
            </div>
            <div class="text-center mt-12">
                <a href="/store" class="neon-btn px-10 py-4 rounded-full font-semibold text-xl inline-block">
                    View All Software <i class="fas fa-arrow-right ml-2"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- Services Section Premium -->
    <section class="py-20 rounded-3xl mx-6 my-6 section-bg shadow-2xl">
        <div class="container mx-auto px-6">
            <h2 class="text-5xl font-bold text-center mb-12">
                <span class="rgb-text">🎯 Our Services</span>
            </h2>
            <div class="grid md:grid-cols-4 gap-6">
                <div class="text-center p-6 glow-card rounded-2xl" data-aos="fade-up">
                    <div class="text-6xl mb-4">💻</div>
                    <h3 class="text-xl font-bold text-cyan-400 mb-2">Custom Software</h3>
                    <p class="text-gray-400">Tailored solutions for your business needs</p>
                </div>
                <div class="text-center p-6 glow-card rounded-2xl" data-aos="fade-up" data-aos-delay="100">
                    <div class="text-6xl mb-4">🔧</div>
                    <h3 class="text-xl font-bold text-cyan-400 mb-2">24/7 Support</h3>
                    <p class="text-gray-400">Round the clock technical assistance</p>
                </div>
                <div class="text-center p-6 glow-card rounded-2xl" data-aos="fade-up" data-aos-delay="200">
                    <div class="text-6xl mb-4">☁️</div>
                    <h3 class="text-xl font-bold text-cyan-400 mb-2">Cloud Integration</h3>
                    <p class="text-gray-400">Seamless cloud deployment</p>
                </div>
                <div class="text-center p-6 glow-card rounded-2xl" data-aos="fade-up" data-aos-delay="300">
                    <div class="text-6xl mb-4">🔒</div>
                    <h3 class="text-xl font-bold text-cyan-400 mb-2">Secure Payment</h3>
                    <p class="text-gray-400">100% secure transactions</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer Premium -->
    <footer class="bg-black/80 backdrop-blur-xl text-white py-12 mt-12 border-t border-green-500/30">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-4 gap-8">
                <div>
                    <h3 class="text-3xl font-bold mb-4">
                        <span class="rgb-text">INDIAN</span>
                        <span class="rgb-text" style="animation-delay: 0.3s;">WEB</span>
                    </h3>
                    <p class="text-gray-400">Premium software solutions for modern businesses.</p>
                    <div class="flex space-x-4 mt-4">
                        <a href="#" class="text-gray-400 hover:text-green-400 text-2xl"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-gray-400 hover:text-green-400 text-2xl"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-gray-400 hover:text-green-400 text-2xl"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-gray-400 hover:text-green-400 text-2xl"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
                <div>
                    <h4 class="font-bold mb-4 text-cyan-400">Quick Links</h4>
                    <ul class="space-y-2 text-gray-400">
                        <li><a href="/store" class="hover:text-green-400">📦 Store</a></li>
                        <li><a href="/custom-order" class="hover:text-green-400">🎨 Custom Order</a></li>
                        <li><a href="/support" class="hover:text-green-400">❓ Support</a></li>
                        <li><a href="/contact" class="hover:text-green-400">📞 Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4 text-cyan-400">Contact Info</h4>
                    <ul class="space-y-2 text-gray-400">
                        <li><i class="fas fa-phone mr-2 text-green-400"></i> <%= (portfolio && portfolio.contactPhone) ? portfolio.contactPhone : '+91 98765 43210' %></li>
                        <li><i class="fas fa-envelope mr-2 text-green-400"></i> <%= (portfolio && portfolio.contactEmail) ? portfolio.contactEmail : 'support@indianweb.com' %></li>
                        <li><i class="fas fa-map-marker-alt mr-2 text-green-400"></i> <%= (portfolio && portfolio.contactAddress) ? portfolio.contactAddress : 'New Delhi, India' %></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4 text-cyan-400">Secure Payments</h4>
                    <div class="flex space-x-4 text-4xl">
                        <span>💳</span> <span>📱</span> <span>🏦</span> <span>🪪</span>
                    </div>
                    <p class="text-gray-400 text-sm mt-4">100% Secure Transactions</p>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8 text-center text-gray-500">
                <p>&copy; 2025 INDIAN WEB. All rights reserved. Designed with premium RGB ❤️ for India</p>
            </div>
        </div>
    </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
    AOS.init({ duration: 1000, once: true });
    
    function updateCartCount() {
        fetch('/api/cart-count')
            .then(res => res.json())
            .then(data => {
                const cartSpan = document.getElementById('cartCount');
                if(cartSpan) cartSpan.innerText = data.count || 0;
            })
            .catch(() => {});
    }
    
    function addToCart(id, name, price) {
        fetch('/add-to-cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ softwareId: id, name, price })
        }).then(res => res.json()).then(data => {
            if(data.success) {
                updateCartCount();
                alert('✅ ' + name + ' added to cart!');
            }
        });
    }
    
    document.addEventListener('DOMContentLoaded', updateCartCount);
</script>
</body>
</html>