<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INDIAN WEB - Premium Software Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Poppins', sans-serif;
        }
        
        /* Premium Background */
        body {
            background: linear-gradient(135deg, #fff9f0 0%, #f0fff4 50%, #fff5e6 100%);
            min-height: 100vh;
        }
        
        /* 4D Flower Animation Container */
        .flower-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        
        .flower {
            position: absolute;
            opacity: 0;
            animation: floatFlower 8s ease-in-out infinite;
        }
        
        @keyframes floatFlower {
            0% {
                opacity: 0;
                transform: translateY(100vh) rotate(0deg) scale(0.3);
            }
            10% {
                opacity: 0.6;
            }
            50% {
                opacity: 0.8;
                transform: translateY(50vh) rotate(180deg) scale(1);
            }
            90% {
                opacity: 0.6;
            }
            100% {
                opacity: 0;
                transform: translateY(-20vh) rotate(360deg) scale(0.5);
            }
        }
        
        .flower:nth-child(1) { left: 10%; animation-duration: 12s; animation-delay: 0s; }
        .flower:nth-child(2) { left: 25%; animation-duration: 15s; animation-delay: 2s; }
        .flower:nth-child(3) { left: 40%; animation-duration: 10s; animation-delay: 4s; }
        .flower:nth-child(4) { left: 55%; animation-duration: 14s; animation-delay: 1s; }
        .flower:nth-child(5) { left: 70%; animation-duration: 11s; animation-delay: 5s; }
        .flower:nth-child(6) { left: 85%; animation-duration: 13s; animation-delay: 3s; }
        .flower:nth-child(7) { left: 15%; animation-duration: 9s; animation-delay: 6s; }
        .flower:nth-child(8) { left: 50%; animation-duration: 16s; animation-delay: 2.5s; }
        .flower:nth-child(9) { left: 75%; animation-duration: 12s; animation-delay: 7s; }
        .flower:nth-child(10) { left: 33%; animation-duration: 11s; animation-delay: 4.5s; }
        .flower:nth-child(11) { left: 88%; animation-duration: 14s; animation-delay: 1.5s; }
        .flower:nth-child(12) { left: 5%; animation-duration: 10s; animation-delay: 8s; }
        
        /* Premium Font Style */
        .premium-text {
            font-family: 'Poppins', sans-serif;
            font-weight: 800;
            letter-spacing: 2px;
            background: linear-gradient(135deg, #ffd700, #ff8c00, #ffa500);
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
            text-shadow: 3px 3px 6px rgba(0,0,0,0.1);
        }
        
        /* Logo Round Shape */
        .logo-round {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid #ff8c00;
            box-shadow: 0 0 20px rgba(255,140,0,0.3);
            transition: transform 0.3s ease;
        }
        
        .logo-round:hover {
            transform: scale(1.05);
            box-shadow: 0 0 30px rgba(255,140,0,0.5);
        }
        
        /* Background Image Container */
        .hero-bg {
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            position: relative;
        }
        
        /* Gradient Button */
        .btn-premium {
            background: linear-gradient(90deg, #ff8c00, #ffa500, #ffb347);
            transition: all 0.3s ease;
        }
        
        .btn-premium:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255,140,0,0.4);
        }
        
        /* Card Hover Effect */
        .software-card {
            transition: all 0.3s ease;
            backdrop-filter: blur(5px);
            background: rgba(255,255,255,0.9);
        }
        
        .software-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(255,140,0,0.2);
        }
        
        /* INDIAN WEB Color Style */
        .indian-text {
            color: #ff8c00;
            text-shadow: 2px 2px 4px rgba(255,140,0,0.2);
        }
        
        .web-text {
            color: #2ecc71;
            text-shadow: 2px 2px 4px rgba(46,204,113,0.2);
        }
        
        /* Content Wrapper (সব কন্টেন্ট উপরে থাকবে) */
        .content-wrapper {
            position: relative;
            z-index: 10;
        }
    </style>
</head>
<body>

<!-- 4D Flower Animation -->
<div class="flower-animation">
    <div class="flower">
        <svg width="50" height="50" viewBox="0 0 50 50" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="25" cy="25" r="8" fill="#ff8c00" fill-opacity="0.6"/>
            <circle cx="25" cy="10" r="6" fill="#ffa500" fill-opacity="0.5"/>
            <circle cx="25" cy="40" r="6" fill="#ffb347" fill-opacity="0.5"/>
            <circle cx="10" cy="25" r="6" fill="#ffcc66" fill-opacity="0.5"/>
            <circle cx="40" cy="25" r="6" fill="#ffdd88" fill-opacity="0.5"/>
            <circle cx="15" cy="15" r="5" fill="#ff8c00" fill-opacity="0.4"/>
            <circle cx="35" cy="15" r="5" fill="#ffa500" fill-opacity="0.4"/>
            <circle cx="15" cy="35" r="5" fill="#ffcc66" fill-opacity="0.4"/>
            <circle cx="35" cy="35" r="5" fill="#ffdd88" fill-opacity="0.4"/>
        </svg>
    </div>
    <div class="flower">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="20" r="6" fill="#2ecc71" fill-opacity="0.6"/>
            <circle cx="20" cy="8" r="5" fill="#27ae60" fill-opacity="0.5"/>
            <circle cx="20" cy="32" r="5" fill="#2ecc71" fill-opacity="0.5"/>
            <circle cx="8" cy="20" r="5" fill="#3be081" fill-opacity="0.5"/>
            <circle cx="32" cy="20" r="5" fill="#2ecc71" fill-opacity="0.5"/>
        </svg>
    </div>
    <div class="flower">
        <svg width="60" height="60" viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="30" cy="30" r="10" fill="#fff9f0" fill-opacity="0.7"/>
            <circle cx="30" cy="12" r="7" fill="#fff0d4" fill-opacity="0.5"/>
            <circle cx="30" cy="48" r="7" fill="#fff5e6" fill-opacity="0.5"/>
            <circle cx="12" cy="30" r="7" fill="#fffaec" fill-opacity="0.5"/>
            <circle cx="48" cy="30" r="7" fill="#fff9f0" fill-opacity="0.5"/>
        </svg>
    </div>
    <!-- আরও ফ্লাওয়ার -->
    <div class="flower"><i class="fas fa-leaf" style="font-size: 30px; color: #2ecc71; opacity: 0.5;"></i></div>
    <div class="flower"><i class="fas fa-leaf" style="font-size: 25px; color: #ff8c00; opacity: 0.4;"></i></div>
    <div class="flower"><i class="fas fa-seedling" style="font-size: 35px; color: #27ae60; opacity: 0.5;"></i></div>
    <div class="flower"><i class="fas fa-feather-alt" style="font-size: 28px; color: #ffa500; opacity: 0.4;"></i></div>
    <div class="flower"><i class="fas fa-pagelines" style="font-size: 32px; color: #2ecc71; opacity: 0.5;"></i></div>
    <div class="flower"><i class="fas fa-feather" style="font-size: 26px; color: #ff8c00; opacity: 0.4;"></i></div>
    <div class="flower"><i class="fas fa-tree" style="font-size: 30px; color: #27ae60; opacity: 0.5;"></i></div>
    <div class="flower"><i class="fas fa-sun" style="font-size: 35px; color: #ffa500; opacity: 0.3;"></i></div>
</div>

<!-- Main Content -->
<div class="content-wrapper">

    <!-- Navbar -->
    <nav class="bg-white/90 backdrop-blur-md shadow-lg sticky top-0 z-50">
        <div class="container mx-auto px-6 py-4">
            <div class="flex justify-between items-center">
                <div class="flex items-center space-x-4">
                    <!-- Round Logo Upload Area -->
                    <% if(locals.siteSettings && locals.siteSettings.logo && locals.siteSettings.logo !== '/uploads/logo/default-logo.png') { %>
                        <img src="<%= locals.siteSettings.logo %>" alt="Logo" class="logo-round">
                    <% } else { %>
                        <div class="logo-round bg-gradient-to-r from-orange-500 to-green-500 flex items-center justify-center text-white text-2xl font-bold">
                            IW
                        </div>
                    <% } %>
                    <!-- Logo Upload Form (Hidden by default, shows in admin mode) -->
                    <% if(user && user.userRole === 'admin') { %>
                        <form action="/admin/upload-logo" method="POST" enctype="multipart/form-data" class="hidden md:block">
                            <input type="file" name="logo" accept="image/*" class="text-xs bg-gray-100 rounded p-1" onchange="this.form.submit()">
                        </form>
                    <% } %>
                    
                    <!-- INDIAN WEB Text with Colors -->
                    <div class="text-4xl font-extrabold tracking-wider">
                        <span class="indian-text">INDIAN</span>
                        <span class="web-text">WEB</span>
                    </div>
                </div>
                
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="text-gray-700 hover:text-orange-500 transition font-medium">Home</a>
                    <a href="/store" class="text-gray-700 hover:text-orange-500 transition font-medium">Store</a>
                    <a href="/custom-order" class="text-gray-700 hover:text-orange-500 transition font-medium">Custom Order</a>
                    <a href="/support" class="text-gray-700 hover:text-orange-500 transition font-medium">Support</a>
                    <a href="/contact" class="text-gray-700 hover:text-orange-500 transition font-medium">Contact</a>
                </div>
                
                <div class="flex items-center space-x-4">
                    <a href="/cart" class="relative text-2xl">
                        🛒
                        <span id="cartCount" class="absolute -top-2 -right-4 bg-red-500 text-white rounded-full px-1.5 py-0.5 text-xs">0</span>
                    </a>
                    <% if(user && user.userId) { %>
                        <span class="text-gray-700 hidden sm:inline">👋 <%= user.userName %></span>
                        <a href="/logout" class="text-red-500 hover:text-red-700">Logout</a>
                    <% } else { %>
                        <a href="/login" class="btn-premium text-white px-5 py-2 rounded-full font-semibold">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section with Background Image Upload -->
    <section class="hero-bg py-24 rounded-3xl mx-6 mt-6 relative overflow-hidden"
         style="background-image: url('<%= locals.siteSettings && locals.siteSettings.heroBackground ? locals.siteSettings.heroBackground : 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?w=1600' %>');">
        <div class="absolute inset-0 bg-black/50"></div>
        <div class="container mx-auto px-6 text-center relative z-10">
            <!-- Admin Background Upload -->
            <% if(user && user.userRole === 'admin') { %>
                <div class="absolute top-4 right-4">
                    <form action="/admin/upload-hero-bg" method="POST" enctype="multipart/form-data">
                        <input type="file" name="heroBackground" accept="image/*" class="text-xs bg-white/80 rounded p-1" onchange="this.form.submit()">
                    </form>
                </div>
            <% } %>
            
            <h1 class="text-6xl md:text-8xl font-bold mb-6" data-aos="fade-up">
                <span class="indian-text">INDIAN</span>
                <span class="web-text">WEB</span>
            </h1>
            <p class="premium-text text-2xl md:text-3xl mb-8 max-w-3xl mx-auto" data-aos="fade-up" data-aos-delay="100">
                Premium Software Solutions
            </p>
            <p class="text-white text-lg mb-10 max-w-2xl mx-auto opacity-90" data-aos="fade-up" data-aos-delay="200">
                <%= portfolio?.heroSubtitle || 'Download high-quality software for your business' %>
            </p>
            <div class="flex flex-col sm:flex-row gap-5 justify-center" data-aos="fade-up" data-aos-delay="300">
                <a href="/store" class="btn-premium text-white px-8 py-4 rounded-full font-bold text-lg shadow-xl hover:shadow-2xl transition inline-block">
                    🚀 Explore Store
                </a>
                <a href="/custom-order" class="border-2 border-white text-white px-8 py-4 rounded-full font-bold text-lg hover:bg-white hover:text-orange-500 transition inline-block">
                    📝 Request Custom Software
                </a>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="py-16 rounded-3xl mx-6 my-6 bg-white/80 backdrop-blur-sm shadow-xl">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-3 gap-8 text-center">
                <div class="p-6" data-aos="zoom-in">
                    <div class="text-5xl text-orange-500 mb-2">📦</div>
                    <div class="text-3xl font-bold"><%= stats.totalSoftware %></div>
                    <div class="text-gray-600">Software Products</div>
                </div>
                <div class="p-6" data-aos="zoom-in" data-aos-delay="100">
                    <div class="text-5xl text-green-500 mb-2">👥</div>
                    <div class="text-3xl font-bold"><%= stats.totalCustomers %></div>
                    <div class="text-gray-600">Happy Customers</div>
                </div>
                <div class="p-6" data-aos="zoom-in" data-aos-delay="200">
                    <div class="text-5xl text-orange-400 mb-2">📝</div>
                    <div class="text-3xl font-bold"><%= stats.totalOrders %></div>
                    <div class="text-gray-600">Orders Completed</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Software -->
    <section class="py-20 rounded-3xl mx-6 my-6 bg-white/80 backdrop-blur-sm shadow-xl">
        <div class="container mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-12">
                <span class="premium-text">⭐ Featured Software</span>
            </h2>
            <div class="grid md:grid-cols-3 gap-8">
                <% if(featuredSoftware && featuredSoftware.length > 0) { %>
                    <% featuredSoftware.forEach((software, index) => { %>
                        <div class="software-card rounded-2xl shadow-lg overflow-hidden border border-orange-100"
                             data-aos="fade-up" data-aos-delay="<%= index * 100 %>">
                            <img src="<%= software.imageUrl %>" alt="<%= software.name %>" class="w-full h-56 object-cover">
                            <div class="p-6">
                                <h3 class="text-xl font-bold mb-2"><%= software.name %></h3>
                                <p class="text-gray-600 mb-4"><%= software.description ? software.description.substring(0, 100) : 'No description' %></p>
                                <div class="flex justify-between items-center">
                                    <div>
                                        <span class="text-2xl font-bold text-orange-500">₹<%= software.price %></span>
                                    </div>
                                    <div class="space-x-2">
                                        <% if(software.demoUrl) { %>
                                            <a href="<%= software.demoUrl %>" target="_blank" class="text-green-500 hover:text-green-700">
                                                <i class="fas fa-eye"></i> Demo
                                            </a>
                                        <% } %>
                                        <button onclick="addToCart('<%= software._id %>', '<%= software.name %>', <%= software.price %>)" 
                                                class="btn-premium text-white px-4 py-2 rounded-lg hover:opacity-90 transition">
                                            Buy Now
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="col-span-3 text-center py-12">
                        <p class="text-gray-500">No software available yet. <a href="/admin/software" class="text-orange-500">Add some software</a></p>
                    </div>
                <% } %>
            </div>
            <div class="text-center mt-12">
                <a href="/store" class="btn-premium text-white px-8 py-3 rounded-full font-semibold inline-block">
                    View All Software <i class="fas fa-arrow-right ml-2"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="py-20 rounded-3xl mx-6 my-6 bg-white/80 backdrop-blur-sm shadow-xl">
        <div class="container mx-auto px-6">
            <h2 class="text-4xl font-bold text-center mb-12">
                <span class="premium-text">🎯 Our Services</span>
            </h2>
            <div class="grid md:grid-cols-4 gap-6">
                <div class="text-center p-6" data-aos="fade-up">
                    <div class="text-5xl mb-4">💻</div>
                    <h3 class="text-xl font-bold mb-2">Custom Software</h3>
                    <p class="text-gray-600">Tailored solutions for your business needs</p>
                </div>
                <div class="text-center p-6" data-aos="fade-up" data-aos-delay="100">
                    <div class="text-5xl mb-4">🔧</div>
                    <h3 class="text-xl font-bold mb-2">24/7 Support</h3>
                    <p class="text-gray-600">Round the clock technical assistance</p>
                </div>
                <div class="text-center p-6" data-aos="fade-up" data-aos-delay="200">
                    <div class="text-5xl mb-4">☁️</div>
                    <h3 class="text-xl font-bold mb-2">Cloud Integration</h3>
                    <p class="text-gray-600">Seamless cloud deployment</p>
                </div>
                <div class="text-center p-6" data-aos="fade-up" data-aos-delay="300">
                    <div class="text-5xl mb-4">🔒</div>
                    <h3 class="text-xl font-bold mb-2">Secure Payment</h3>
                    <p class="text-gray-600">100% secure transactions</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="bg-gradient-to-r from-orange-900 to-green-900 text-white py-12 mt-12">
        <div class="container mx-auto px-6">
            <div class="grid md:grid-cols-4 gap-8">
                <div>
                    <h3 class="text-2xl font-bold mb-4">
                        <span class="text-orange-400">INDIAN</span>
                        <span class="text-green-400">WEB</span>
                    </h3>
                    <p class="text-gray-300">Premium software solutions for modern businesses.</p>
                    <div class="flex space-x-4 mt-4">
                        <a href="#" class="text-gray-300 hover:text-orange-400 text-xl"><i class="fab fa-facebook"></i></a>
                        <a href="#" class="text-gray-300 hover:text-orange-400 text-xl"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-gray-300 hover:text-orange-400 text-xl"><i class="fab fa-instagram"></i></a>
                        <a href="#" class="text-gray-300 hover:text-orange-400 text-xl"><i class="fab fa-linkedin"></i></a>
                    </div>
                </div>
                <div>
                    <h4 class="font-bold mb-4">Quick Links</h4>
                    <ul class="space-y-2 text-gray-300">
                        <li><a href="/store" class="hover:text-orange-400">📦 Store</a></li>
                        <li><a href="/custom-order" class="hover:text-orange-400">🎨 Custom Order</a></li>
                        <li><a href="/support" class="hover:text-orange-400">❓ Support</a></li>
                        <li><a href="/contact" class="hover:text-orange-400">📞 Contact</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4">Contact Info</h4>
                    <ul class="space-y-2 text-gray-300">
                        <li><i class="fas fa-phone mr-2"></i> <%= portfolio?.contactPhone || '+91 98765 43210' %></li>
                        <li><i class="fas fa-envelope mr-2"></i> <%= portfolio?.contactEmail || 'support@indianweb.com' %></li>
                        <li><i class="fas fa-map-marker-alt mr-2"></i> <%= portfolio?.contactAddress || 'New Delhi, India' %></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4">Secure Payments</h4>
                    <div class="flex space-x-4 text-3xl">
                        <span>💳</span> <span>📱</span> <span>🏦</span> <span>🪪</span>
                    </div>
                    <p class="text-gray-300 text-sm mt-4">100% Secure Transactions</p>
                </div>
            </div>
            <div class="border-t border-orange-700 mt-8 pt-8 text-center text-gray-400">
                <p>&copy; 2025 INDIAN WEB. All rights reserved. Designed with premium ❤️ for India</p>
            </div>
        </div>
    </footer>
</div>

<script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
<script>
    AOS.init({ duration: 1000, once: true });
    
    function updateCartCount() {
        fetch('/api/cart-count')
            .then(res => res.json())
            .then(data => {
                const cartSpan = document.getElementById('cartCount');
                if(cartSpan) cartSpan.innerText = data.count || 0;
            })
            .catch(() => {});
    }
    
    function addToCart(id, name, price) {
        fetch('/add-to-cart', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ softwareId: id, name, price })
        }).then(res => res.json()).then(data => {
            if(data.success) {
                updateCartCount();
                alert('✅ ' + name + ' added to cart!');
            }
        });
    }
    
    document.addEventListener('DOMContentLoaded', updateCartCount);
</script>
</body>
</html>