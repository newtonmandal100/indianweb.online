<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>INDIAN WEB - Premium Software Solutions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <!-- Premium Navbar -->
    <nav class="navbar-premium">
        <div class="container">
            <div class="flex justify-between items-center py-4">
                <div class="logo-text text-2xl font-bold">
                    <span class="text-gradient">INDIAN</span>
                    <span class="text-gradient">WEB</span>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="/" class="hover:text-[#ff6b35] transition">Home</a>
                    <a href="/store" class="hover:text-[#ff6b35] transition">Store</a>
                    <a href="/custom-order" class="hover:text-[#ff6b35] transition">Custom Order</a>
                    <a href="/blog" class="hover:text-[#ff6b35] transition">Blog</a>
                    <a href="/support" class="hover:text-[#ff6b35] transition">Support</a>
                </div>
                <div class="flex items-center space-x-4">
                    <button id="darkModeToggle" class="text-2xl">🌙</button>
                    <a href="/cart" class="relative text-2xl">🛒<span id="cartCount" class="absolute -top-2 -right-4 bg-[#ff6b35] text-white rounded-full px-1 text-xs">0</span></a>
                    <% if(user && user.userId) { %>
                        <span>👋 <%= user.userName %></span>
                        <a href="/logout" class="text-red-400">Logout</a>
                    <% } else { %>
                        <a href="/login" class="btn-premium">Login</a>
                    <% } %>
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section with 3D Effect -->
    <section class="relative overflow-hidden py-32">
        <div class="container text-center">
            <h1 class="text-6xl md:text-8xl font-bold mb-6 text-3d neon-text" data-aos="fade-up">
                Premium <span class="text-gradient">Software</span> Solutions
            </h1>
            <p class="text-xl md:text-2xl mb-10 text-white/80" data-aos="fade-up" data-aos-delay="100">
                Download high-quality software for your business at affordable prices
            </p>
            <div class="space-x-4" data-aos="fade-up" data-aos-delay="200">
                <a href="/store" class="btn-premium inline-block">🚀 Explore Store</a>
                <a href="/custom-order" class="border-2 border-[#ff6b35] text-white px-8 py-3 rounded-full hover:bg-[#ff6b35] transition inline-block">📝 Custom Order</a>
            </div>
        </div>
        
        <!-- 3D Floating Elements -->
        <div class="absolute top-20 left-10 float-3d text-6xl">💻</div>
        <div class="absolute bottom-20 right-10 float-3d text-6xl" style="animation-delay: 1s;">🚀</div>
        <div class="absolute top-40 right-20 float-3d text-5xl" style="animation-delay: 0.5s;">⚡</div>
    </section>

    <!-- Stats Section with Glass Cards -->
    <section class="py-16">
        <div class="container">
            <div class="grid md:grid-cols-4 gap-6">
                <div class="glass-card p-8 text-center card-3d" data-aos="zoom-in">
                    <div class="text-5xl mb-4 icon-3d">📦</div>
                    <div class="text-3xl font-bold"><%= stats.totalSoftware %></div>
                    <div class="text-white/70">Software Products</div>
                </div>
                <div class="glass-card p-8 text-center card-3d" data-aos="zoom-in" data-aos-delay="100">
                    <div class="text-5xl mb-4 icon-3d">👥</div>
                    <div class="text-3xl font-bold"><%= stats.totalCustomers %></div>
                    <div class="text-white/70">Happy Customers</div>
                </div>
                <div class="glass-card p-8 text-center card-3d" data-aos="zoom-in" data-aos-delay="200">
                    <div class="text-5xl mb-4 icon-3d">📝</div>
                    <div class="text-3xl font-bold"><%= stats.totalOrders %></div>
                    <div class="text-white/70">Orders Completed</div>
                </div>
                <div class="glass-card p-8 text-center card-3d" data-aos="zoom-in" data-aos-delay="300">
                    <div class="text-5xl mb-4 icon-3d">⭐</div>
                    <div class="text-3xl font-bold">4.9</div>
                    <div class="text-white/70">Customer Rating</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Featured Software Section -->
    <section class="py-20">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <h2 class="text-gradient">⭐ Featured Software</h2>
                <p>Discover our most popular software products</p>
            </div>
            <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-8">
                <% featuredSoftware.forEach((software, index) => { %>
                <div class="card-3d rounded-2xl overflow-hidden" data-aos="flip-left" data-aos-delay="<%= index * 100 %>">
                    <img src="<%= software.imageUrl %>" class="w-full h-48 object-cover">
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2"><%= software.name %></h3>
                        <p class="text-white/70 text-sm mb-4"><%= software.description.substring(0, 80) %></p>
                        <div class="flex justify-between items-center">
                            <span class="text-2xl font-bold text-[#ff6b35]">₹<%= software.price %></span>
                            <button onclick="addToCart('<%= software._id %>', '<%= software.name %>', <%= software.price %>)" 
                                    class="btn-premium text-sm px-4 py-2">Buy Now</button>
                        </div>
                    </div>
                </div>
                <% }); %>
            </div>
        </div>
    </section>

    <!-- Premium Services Section -->
    <section class="py-20">
        <div class="container">
            <div class="section-header" data-aos="fade-up">
                <h2 class="text-gradient">🎯 Premium Services</h2>
                <p>What makes us different</p>
            </div>
            <div class="grid md:grid-cols-4 gap-6">
                <div class="glass-card p-6 text-center card-3d" data-aos="fade-up">
                    <div class="text-5xl mb-4 icon-3d">💻</div>
                    <h3 class="text-xl font-bold mb-2">Custom Software</h3>
                    <p class="text-white/70 text-sm">Tailored solutions for your business needs</p>
                </div>
                <div class="glass-card p-6 text-center card-3d" data-aos="fade-up" data-aos-delay="100">
                    <div class="text-5xl mb-4 icon-3d">🔧</div>
                    <h3 class="text-xl font-bold mb-2">24/7 Support</h3>
                    <p class="text-white/70 text-sm">Round the clock technical assistance</p>
                </div>
                <div class="glass-card p-6 text-center card-3d" data-aos="fade-up" data-aos-delay="200">
                    <div class="text-5xl mb-4 icon-3d">☁️</div>
                    <h3 class="text-xl font-bold mb-2">Cloud Integration</h3>
                    <p class="text-white/70 text-sm">Seamless cloud deployment</p>
                </div>
                <div class="glass-card p-6 text-center card-3d" data-aos="fade-up" data-aos-delay="300">
                    <div class="text-5xl mb-4 icon-3d">🔒</div>
                    <h3 class="text-xl font-bold mb-2">Secure Payment</h3>
                    <p class="text-white/70 text-sm">100% secure transactions</p>
                </div>
            </div>
        </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20">
        <div class="container">
            <div class="rgb-border p-12 rounded-3xl text-center">
                <h2 class="text-4xl font-bold mb-4">Ready to Get Started?</h2>
                <p class="text-xl mb-8 text-white/80">Join thousands of satisfied customers using INDIAN WEB</p>
                <a href="/register" class="btn-premium inline-block text-lg">Create Free Account →</a>
            </div>
        </div>
    </section>

    <!-- Premium Footer -->
    <footer class="footer-premium">
        <div class="container">
            <div class="grid md:grid-cols-4 gap-8">
                <div>
                    <h3 class="text-2xl font-bold mb-4 text-gradient">INDIAN WEB</h3>
                    <p class="text-white/70">Premium software solutions for modern businesses.</p>
                </div>
                <div>
                    <h4 class="font-bold mb-4">Quick Links</h4>
                    <ul class="space-y-2 text-white/70">
                        <li><a href="/store" class="hover:text-[#ff6b35]">Store</a></li>
                        <li><a href="/custom-order" class="hover:text-[#ff6b35]">Custom Order</a></li>
                        <li><a href="/blog" class="hover:text-[#ff6b35]">Blog</a></li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4">Contact</h4>
                    <ul class="space-y-2 text-white/70">
                        <li><i class="fas fa-phone mr-2"></i> +91 98765 43210</li>
                        <li><i class="fas fa-envelope mr-2"></i> support@indianweb.com</li>
                    </ul>
                </div>
                <div>
                    <h4 class="font-bold mb-4">Secure Payments</h4>
                    <div class="flex space-x-4 text-3xl">
                        <span>💳</span> <span>📱</span> <span>🏦</span>
                    </div>
                </div>
            </div>
            <div class="border-t border-white/10 mt-8 pt-8 text-center text-white/50">
                <p>&copy; 2025 INDIAN WEB. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/aos@2.3.4/dist/aos.js"></script>
    <script src="/js/3d-effects.js"></script>
    <script src="/js/main.js"></script>
    <script>
        AOS.init({ duration: 1000, once: true });
        
        function addToCart(id, name, price) {
            fetch('/add-to-cart', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ softwareId: id, name, price })
            }).then(res => res.json()).then(data => {
                if(data.success) {
                    alert('✅ ' + name + ' added to cart!');
                    location.reload();
                }
            });
        }
        
        // Dark Mode Toggle
        const darkModeToggle = document.getElementById('darkModeToggle');
        if (localStorage.getItem('darkMode') === 'enabled') {
            document.body.classList.add('dark-mode');
            darkModeToggle.textContent = '☀️';
        }
        darkModeToggle.addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            if (document.body.classList.contains('dark-mode')) {
                localStorage.setItem('darkMode', 'enabled');
                darkModeToggle.textContent = '☀️';
            } else {
                localStorage.setItem('darkMode', 'disabled');
                darkModeToggle.textContent = '🌙';
            }
        });
    </script>
</body>
</html>