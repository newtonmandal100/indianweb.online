<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { font-family: 'Poppins', sans-serif; }
        body {
            background: linear-gradient(135deg, #0a0a2a 0%, #1a1a3a 100%);
            min-height: 100vh;
        }
        .glow-card {
            background: rgba(20, 20, 50, 0.9);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(0, 255, 0, 0.2);
            transition: all 0.3s ease;
        }
        .glow-card:hover {
            border-color: #00ff00;
            box-shadow: 0 0 30px rgba(0, 255, 0, 0.2);
        }
        .neon-btn {
            background: linear-gradient(90deg, #00ff00, #0088ff);
            transition: all 0.3s ease;
        }
        .neon-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 20px #00ff00;
        }
    </style>
</head>
<body class="flex items-center justify-center p-6">
    <div class="w-full max-w-md">
        <div class="text-center mb-8">
            <h1 class="text-5xl font-bold">
                <span class="text-orange-500">INDIAN</span>
                <span class="text-green-500">WEB</span>
            </h1>
            <p class="text-cyan-400 mt-2">Welcome back!</p>
        </div>
        
        <div class="glow-card rounded-2xl p-8">
            <% if(error) { %>
                <div class="bg-red-500/20 border border-red-500 text-red-400 p-3 rounded-lg mb-4 text-center">
                    <%= error %>
                </div>
            <% } %>
            
            <form action="/login" method="POST">
                <div class="mb-4">
                    <label class="text-cyan-400 block mb-2">Email</label>
                    <input type="email" name="email" required 
                           class="w-full p-3 rounded-lg bg-black/50 border border-green-500/30 text-white focus:border-green-500 outline-none">
                </div>
                
                <div class="mb-6">
                    <label class="text-cyan-400 block mb-2">Password</label>
                    <input type="password" name="password" required 
                           class="w-full p-3 rounded-lg bg-black/50 border border-green-500/30 text-white focus:border-green-500 outline-none">
                </div>
                
                <button type="submit" class="neon-btn w-full py-3 rounded-lg font-bold text-white text-lg">
                    Login →
                </button>
            </form>
            
            <div class="text-center mt-6">
                <p class="text-gray-400">Don't have an account? 
                    <a href="/register" class="text-green-400 hover:text-green-300">Register here</a>
                </p>
            </div>
        </div>
    </div>
</body>
</html>