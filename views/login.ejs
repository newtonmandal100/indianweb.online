<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .btn-orange {
            background: linear-gradient(90deg, #FF6B35 0%, #FF8C42 100%);
            transition: all 0.3s ease;
        }
        .btn-orange:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 25px rgba(255, 107, 53, 0.3);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-orange-50 to-green-50 min-h-screen">
    <div class="min-h-screen flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
            <div class="text-center mb-8">
                <div class="text-4xl mb-3">
                    <span class="text-orange-500">🔐</span>
                </div>
                <h1 class="text-3xl font-bold">
                    <span class="text-orange-500">INDIAN</span>
                    <span class="text-green-500">WEB</span>
                </h1>
                <p class="text-gray-500 mt-2">Welcome back! Please login to your account</p>
            </div>
            
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4 flex items-center">
                <i class="fas fa-exclamation-circle mr-2"></i> Invalid email or password!
            </div>
            <% } %>
            
            <form action="/login" method="POST">
                <div class="mb-4">
                    <label class="block text-gray-700 font-medium mb-2">Email Address</label>
                    <input type="email" name="email" placeholder="Enter your email" required 
                           class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-400">
                </div>
                <div class="mb-6">
                    <label class="block text-gray-700 font-medium mb-2">Password</label>
                    <input type="password" name="password" placeholder="Enter your password" required 
                           class="w-full p-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-400">
                </div>
                <button type="submit" class="w-full btn-orange text-white py-3 rounded-lg font-bold text-lg">
                    Login
                </button>
            </form>
            
            <div class="text-center mt-6">
                <p class="text-gray-500">Don't have an account? 
                    <a href="/register" class="text-orange-500 font-semibold hover:underline">Register Now</a>
                </p>
            </div>
            
            <div class="mt-6 pt-6 border-t text-center">
                <a href="/" class="text-gray-400 hover:text-orange-500 text-sm">
                    <i class="fas fa-arrow-left mr-1"></i> Back to Home
                </a>
            </div>
        </div>
    </div>
</body>
</html>