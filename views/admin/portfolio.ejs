<!DOCTYPE html>
<html><head><title>Portfolio Management</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-gray-100"><div class="flex"><div class="w-64 bg-purple-900 text-white p-6"><h2>INDIAN WEB</h2></div><div class="flex-1 p-8">
<h1 class="text-3xl font-bold mb-6">Portfolio Management</h1>
<div class="bg-white rounded-xl p-6">
<form action="/admin/portfolio" method="POST">
<input type="text" name="heroTitle" value="<%= portfolio.heroTitle %>" placeholder="Hero Title" class="w-full p-3 border rounded mb-4">
<input type="text" name="heroSubtitle" value="<%= portfolio.heroSubtitle %>" placeholder="Hero Subtitle" class="w-full p-3 border rounded mb-4">
<input type="text" name="companyName" value="<%= portfolio.companyName %>" placeholder="Company Name" class="w-full p-3 border rounded mb-4">
<textarea name="companyDescription" rows="3" class="w-full p-3 border rounded mb-4"><%= portfolio.companyDescription %></textarea>
<input type="email" name="contactEmail" value="<%= portfolio.contactEmail %>" placeholder="Contact Email" class="w-full p-3 border rounded mb-4">
<input type="text" name="contactPhone" value="<%= portfolio.contactPhone %>" placeholder="Contact Phone" class="w-full p-3 border rounded mb-4">
<input type="text" name="contactAddress" value="<%= portfolio.contactAddress %>" placeholder="Address" class="w-full p-3 border rounded mb-4">
<button type="submit" class="bg-purple-600 text-white py-3 rounded w-full font-bold">Save Changes</button>
</form>
</div></div></div></body></html>