<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><title>Custom Orders</title><script src="https://cdn.tailwindcss.com"></script></head>
<body class="bg-gray-100">
    <div class="flex"><div class="w-64 bg-purple-900 text-white p-6"><h2>INDIAN WEB</h2><nav><a href="/admin/dashboard" class="block">Dashboard</a><a href="/admin/custom-orders" class="block bg-purple-700">Custom Orders</a></nav></div>
    <div class="flex-1 p-8">
        <h1 class="text-3xl font-bold mb-6">Custom Software Requests</h1>
        <div class="bg-white rounded-xl shadow-lg p-6">
            <% customOrders.forEach(order => { %>
            <div class="border p-4 mb-4 rounded">
                <h3 class="font-bold"><%= order.softwareName %></h3>
                <p>From: <%= order.customerName %> (<%= order.customerEmail %>)</p>
                <p><%= order.description %></p>
                <p>Budget: <%= order.budget %> | Timeline: <%= order.timeline %></p>
                <form action="/admin/custom-orders/update/<%= order._id %>" method="POST" class="mt-2">
                    <select name="status"><option <%= order.status==='pending'?'selected':'' %>>pending</option><option <%= order.status==='reviewed'?'selected':'' %>>reviewed</option><option <%= order.status==='approved'?'selected':'' %>>approved</option><option <%= order.status==='completed'?'selected':'' %>>completed</option></select>
                    <input type="text" name="adminNote" placeholder="Admin Note" class="border p-1">
                    <button type="submit" class="bg-blue-600 text-white px-3 py-1 rounded">Update</button>
                </form>
            </div>
            <% }); %>
        </div>
    </div></div>
</body>
</html>