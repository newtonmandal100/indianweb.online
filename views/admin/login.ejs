<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login - INDIAN WEB</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gradient-to-r from-purple-600 to-pink-600">

    <div class="min-h-screen flex items-center justify-center">
        <div class="bg-white rounded-2xl shadow-2xl p-8 w-full max-w-md">
            <div class="text-center mb-8">
                <div class="text-5xl mb-3">🔐</div>
                <h1 class="text-3xl font-bold bg-gradient-to-r from-purple-600 to-pink-600 bg-clip-text text-transparent">Admin Login</h1>
                <p class="text-gray-500">INDIAN WEB Admin Panel</p>
            </div>
            
            <% if(locals.query && locals.query.error) { %>
            <div class="bg-red-100 text-red-700 p-3 rounded-lg mb-4">Invalid credentials!</div>
            <% } %>
            
            <form action="/admin/login" method="POST">
                <input type="email" name="email" placeholder="Admin Email" required class="w-full p-3 border rounded-lg mb-4">
                <input type="password" name="password" placeholder="Password" required class="w-full p-3 border rounded-lg mb-6">
                <button type="submit" class="w-full bg-gradient-to-r from-purple-600 to-pink-600 text-white py-3 rounded-lg font-bold">Login</button>
            </form>
            
            <div class="text-center mt-6 text-gray-400 text-sm">
                <p>Newton Mandal - Admin Access Only</p>
            </div>
        </div>
    </div>
</body>
</html>